# ======================================================================
# RTBIO ERP — 환경변수 샘플
# 로컬 개발은 이 파일을 .env.local 로 복사해서 사용 (.env.local 은 gitignore)
# ======================================================================

# --- Database (Docker PostgreSQL) ---
DATABASE_URL="postgresql://rtbio:rtbio_dev_pw@localhost:5432/rtbio_erp?schema=public"
DIRECT_URL="postgresql://rtbio:rtbio_dev_pw@localhost:5432/rtbio_erp?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_use_openssl_rand_base64_32"

# --- SMTP (Daum) — Phase 7 이메일 발송 ---
SMTP_HOST="smtp.daum.net"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="알티바이오 <noreply@daum.net>"

# --- Flowise 연동 API 토큰 (외부 에이전트가 위젯 생성/데이터 조회) ---
# 설정 시 활성. 절대 커밋 금지. 운영은 회전 가능한 비밀로.
WIDGET_API_TOKEN=""

# --- Flowise 인앱 AI 위젯 입구 (자연어 → 위젯 추천/생성) ---
# 설정 시 POST /api/dashboard/widgets/ai 가 이 챗플로우 예측 URL 로 프록시(후속 구현).
# 빈값이면 로컬 템플릿 추천 엔진 사용. 키/URL 은 서버 env 전용 — 절대 커밋 금지.
FLOWISE_PREDICTION_URL=""
FLOWISE_API_KEY=""

# --- Azure Blob (Phase 9 배포 시) ---
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="rtbio-invoices"

# --- 타임존 (KST 고정) ---
# 모든 "현재 시점" 집계(이번달/오늘/주간 매출, 월간보고서, 유통기한 등)는 런타임 TZ 를 따른다.
# next.config.mjs 가 미설정 시 Asia/Seoul 로 기본 고정하지만, 운영 컨테이너(리눅스 기본 UTC)는
# 컨테이너 env 로도 명시 권장 — 안 하면 KST 와 9시간 어긋나 일/월 경계가 틀어진다.
TZ="Asia/Seoul"

# --- 개발 플래그 ---
NODE_ENV="development"
LOG_LEVEL="debug"
