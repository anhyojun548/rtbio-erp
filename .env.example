# ======================================================================
# RTBIO ERP — 환경변수 샘플
# 로컬 개발은 이 파일을 .env.local 로 복사해서 사용 (.env.local 은 gitignore)
# ======================================================================

# --- Database (Docker PostgreSQL) ---
DATABASE_URL="postgresql://rtbio:rtbio_dev_pw@localhost:5432/rtbio_erp?schema=public"
DIRECT_URL="postgresql://rtbio:rtbio_dev_pw@localhost:5432/rtbio_erp?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_use_openssl_rand_base64_32"

# --- SMTP (Daum) — Phase 7 이메일 발송 ---
SMTP_HOST="smtp.daum.net"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="알티바이오 <noreply@daum.net>"

# --- Azure Blob (Phase 9 배포 시) ---
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="rtbio-invoices"

# --- 개발 플래그 ---
NODE_ENV="development"
LOG_LEVEL="debug"
