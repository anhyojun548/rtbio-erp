// ============================================================================
// RTBIO ERP — Prisma Schema (Phase 1 초안, 2026-04-18)
// ============================================================================
// 설계 원칙 (CLAUDE.md 참조):
//   1. 멀티테넌시: public + tenant_{id} (스키마 분리)
//   2. 가격 스냅샷: 주문 확정 시점 단가를 OrderItem 에 고정
//   3. 재고 이중관리: physicalStock / availableStock
//   4. 반품 = InventoryAdjustment + reason='반품'
//   5. 감사 컬럼: createdAt / updatedAt / createdBy 필수
//   6. 외래키 CASCADE 는 각 관계 주석으로 명시
// ----------------------------------------------------------------------------
// 본 파일은 샘플 테넌트 `tenant_altibio` 기준으로 작성. 실제 운영 시에는
// 테넌트 추가 시 schemas 배열 확장 + 런타임 마이그레이션 스크립트 사용.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "tenant_altibio"]
}

// ============================================================================
// ▼ public 스키마 — 공용 (인증, 테넌시, 감사)
// ============================================================================

enum UserRole {
  SUPER_ADMIN // 전체 운영사 (하마다랩스)
  TENANT_OWNER // 테넌트 대표 (CEO)
  ADMIN // 경영지원
  QC // 품질관리
  EXEC // 영업
  CLIENT // 거래처
  VIEWER // 조회 전용

  @@schema("public")
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique // 스키마명 접미사 (예: "altibio" → tenant_altibio)
  name      String
  subdomain String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  users     User[]
  auditLogs AuditLog[]

  @@index([subdomain])
  @@schema("public")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String // bcrypt hash
  name        String
  role        UserRole
  tenantId    String? // null = SUPER_ADMIN
  clientId    String? // CLIENT 역할 유저가 어떤 거래처를 대변하는지 (앱-레벨 FK; 크로스스키마 제약 회피)
  phone       String?
  active      Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?

  // CASCADE: 테넌트 삭제 시 사용자도 삭제 (운영사 SUPER_ADMIN 제외)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  auditLogs AuditLog[]

  @@index([tenantId])
  @@index([email])
  @@index([clientId])
  @@schema("public")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  tenantId  String?
  userId    String?
  action    String // 예: "ORDER_CREATE", "INVENTORY_ADJUST"
  resource  String // 예: "Order:abc123"
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  // CASCADE: 테넌트/유저 삭제 시에도 감사로그는 보존 → SET NULL
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, timestamp])
  @@index([resource])
  @@schema("public")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@schema("public")
}

// ============================================================================
// ▼ tenant_altibio 스키마 — 테넌트 격리 데이터
// ============================================================================

// ----------------------------------------------------------------------------
// R08: 제품 및 재고 관리
// ----------------------------------------------------------------------------

model Product {
  id           String   @id @default(cuid())
  code         String   @unique // 자체 제품코드
  name         String
  brand        String?
  category     String? // 카테고리 (할인율 테이블 키)
  part         String? // 부위 (예: 상완, 하지)
  basePrice    Decimal  @db.Decimal(12, 2)
  active       Boolean  @default(true)
  expiryMonths Int? // 유통기한(개월) — R19

  // ── UDI (의료기기 고유식별, 식약처 의료기기통합정보시스템 udiportal.mfds.go.kr) ──
  // 알티바이오가 사전 UDI 등록을 완료한 제품만 udiCode 가 채워짐.
  // udiCode 가 NULL 인 제품은 공급내역 보고에서 제외 (미등록 = 보고 불가).
  udiCode           String?   @unique // UDI-DI 14자리 (예: 08801234567890)
  udiRegisteredAt   DateTime? // 식약처 UDI 등록 완료일
  udiCertificateUrl String?   // 등록증 PDF 경로 (선택, Blob Storage)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  sizes       ProductSize[]
  orderItems  OrderItem[]
  fixedPrices ClientFixedPrice[]

  @@index([category])
  @@index([brand])
  @@index([udiCode])
  @@schema("tenant_altibio")
}

model ProductSize {
  id             String   @id @default(cuid())
  productId      String
  sizeCode       String // 예: "S", "M", "L", "12x8"
  physicalStock  Int      @default(0) // 실재고
  availableStock Int      @default(0) // 가용재고 (예약분 제외)
  reorderPoint   Int? // 재고 알람 기준 (월평균×2.5 등) — R14
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?

  // CASCADE: 제품 삭제 시 사이즈도 삭제
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]
  adjustments   InventoryAdjustment[]
  expiryLots    ExpiryLot[]

  @@unique([productId, sizeCode])
  @@index([productId])
  @@schema("tenant_altibio")
}

// R19: 유통기한 관리 — 로트별 잔여수량 추적
model ExpiryLot {
  id            String   @id @default(cuid())
  productSizeId String
  lotNumber     String
  expiryDate    DateTime
  quantity      Int
  remainingQty  Int
  receivedAt    DateTime @default(now())
  note          String?

  // CASCADE: 제품사이즈 삭제 시 로트도 삭제
  productSize ProductSize @relation(fields: [productSizeId], references: [id], onDelete: Cascade)

  @@index([productSizeId, expiryDate])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R01, R02: 거래처 및 할인율
// ----------------------------------------------------------------------------

enum ClientType {
  AGENCY // 대리점
  HOSPITAL // 병원
  PHARMACY // 약국 (향후 확장용 — 현재 미사용)
  OTHER // 기타

  @@schema("tenant_altibio")
}

model Client {
  id             String     @id @default(cuid())
  code           String     @unique
  name           String
  type           ClientType
  businessNumber String? // 사업자번호
  representative String? // 대표자
  phone          String?
  email          String?
  address        String?
  postalCode     String?
  paymentTerms   String? // 결제조건 (예: "월말 25일 발주, 다음달 말 입금")
  salesRepId     String? // 담당 영업사원
  active         Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  createdBy      String?

  discounts   ClientDiscount[]
  fixedPrices ClientFixedPrice[]
  addresses   ClientAddress[]
  orders      Order[]
  invoices    Invoice[]
  ledgers     ClosingLedger[]
  payments    Payment[]
  assignments SalesAssignment[]
  contracts   SalesContract[]

  // Phase 5 신규 모듈 (2026-05-22)
  noticeRecipients NoticeRecipient[]
  noticeReadLogs   NoticeReadLog[]
  udiReportItems   UdiReportItem[]

  @@index([type])
  @@index([salesRepId])
  @@schema("tenant_altibio")
}

// 거래처 배송지 (복수 등록) — 하나의 거래처가 여러 곳에 배송 가능
// 발주 시 이 목록에서 선택 → Order 에 스냅샷 저장
// CASCADE: 거래처 삭제 시 배송지 함께 삭제, 과거 주문은 스냅샷으로 보존
model ClientAddress {
  id            String   @id @default(cuid())
  clientId      String
  label         String // 배송지 별칭 (예: "본점 창고", "강남지점", "대구 물류센터")
  recipientName String? // 수령인 이름 (비어있으면 거래처 담당자 사용)
  phone         String? // 수령인 연락처
  postalCode    String?
  address       String // 기본 주소
  addressDetail String? // 상세 주소 (동/호수 등)
  memo          String? // 배송 메모 (예: "3층 창고 옆 문으로", "금~월요일 수령 불가")
  isDefault     Boolean  @default(false) // 기본 배송지 플래그 (거래처당 1개 권장, 앱 로직으로 enforce)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([clientId, active])
  @@index([clientId, isDefault])
  @@schema("tenant_altibio")
}

// 우선순위 중간: discounts[category] (R02)
model ClientDiscount {
  id           String   @id @default(cuid())
  clientId     String
  category     String // Product.category 와 매칭
  discountRate Decimal  @db.Decimal(5, 4) // 0.0000 ~ 1.0000
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  // CASCADE: 거래처 삭제 시 할인율도 삭제
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, category])
  @@schema("tenant_altibio")
}

// 우선순위 최상: fixedPrices (R02)
model ClientFixedPrice {
  id         String   @id @default(cuid())
  clientId   String
  productId  String
  fixedPrice Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?

  // CASCADE: 거래처/제품 삭제 시 고정가도 삭제
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([clientId, productId])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R03, R04, R13: 주문 (발주 → 확정 → 출고)
// ----------------------------------------------------------------------------

enum OrderStatus {
  DRAFT // 거래처 작성중
  SUBMITTED // 발주 제출 (거래처 → QC)
  CONFIRMED // QC 확정 (가용재고 차감 완료)
  HOLD // 보류 (이월)
  REJECTED // 반려
  SHIPPING // 출고 진행중 (칸반)
  COMPLETED // 출고 완료
  CANCELLED // 취소

  @@schema("tenant_altibio")
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique // 예: "ORD-20260418-001"
  clientId      String
  status        OrderStatus @default(DRAFT)
  orderDate     DateTime
  requestedDate DateTime? // 희망 배송일
  confirmedAt   DateTime?
  shippedAt     DateTime?
  completedAt   DateTime?
  invoiceIssued Boolean     @default(false) // R07 연동
  note          String?

  // 상태 전이 사유 (Phase 3D-2b-2 —  REJECT / HOLD 추적용)
  rejectedAt     DateTime?
  rejectedReason String? // REJECTED 시 사유 (3~500자)
  heldAt         DateTime?
  heldReason     String? // HOLD 시 사유 (3~500자, RESUME 시 null 로 복귀)
  // 월 1~25일 발주 → 월말 입금 규칙 (R12) 체크용
  billingMonth   String? // "2026-04" 형식

  // ── 배송지 (선택된 ClientAddress 의 스냅샷 — 가격 스냅샷과 동일 철학)
  // 발주 제출 시 ClientAddress 내용을 고정 기록. 이후 배송지가 수정/삭제돼도 주문은 영향 없음.
  shipToAddressId     String? // 선택된 배송지 참조 (Nullable: 임시주소/직접입력 대응)
  shipToLabel         String? // 스냅샷: 배송지 별칭
  shipToRecipient     String? // 스냅샷: 수령인
  shipToPhone         String? // 스냅샷: 연락처
  shipToPostalCode    String?
  shipToAddress       String? // 스냅샷: 기본 주소
  shipToAddressDetail String? // 스냅샷: 상세 주소
  shipToMemo          String? // 스냅샷: 배송 메모

  shipMethod String? // "택배" / "방문수령" / "퀵"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // CASCADE: 거래처 삭제 시 주문은 SET NULL → 감사상 보존
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  shipToAddress_ ClientAddress? @relation(fields: [shipToAddressId], references: [id], onDelete: SetNull)

  items     OrderItem[]
  shipments Shipment[]
  invoices  Invoice[]

  @@index([clientId, orderDate])
  @@index([status])
  @@index([orderDate])
  @@index([shipToAddressId])
  @@schema("tenant_altibio")
}

// 가격 스냅샷 — 주문 확정 시 단가/할인 고정
model OrderItem {
  id                       String   @id @default(cuid())
  orderId                  String
  productId                String
  productSizeId            String
  quantity                 Int
  // 스냅샷 (CLAUDE.md 도메인 규칙)
  unitPrice                Decimal  @db.Decimal(12, 2) // 최종 단가
  basePriceAtOrder         Decimal  @db.Decimal(12, 2) // 주문 시점 기준가
  discountRateAtOrder      Decimal? @db.Decimal(5, 4) // 적용된 할인율
  fixedPriceAppliedAtOrder Boolean  @default(false) // fixedPrice 적용 여부
  lineTotal                Decimal  @db.Decimal(14, 2) // unitPrice * quantity
  createdAt                DateTime @default(now())

  // CASCADE: 주문 삭제 시 라인도 삭제
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  productSize ProductSize @relation(fields: [productSizeId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R05, R17: 출고 칸반 (커스터마이징 단계)
// ----------------------------------------------------------------------------

// 테넌트별 칸반 단계 정의 (최대 8단계)
model KanbanColumn {
  id         String   @id @default(cuid())
  key        String   @unique // 코드 (예: "RECEIVED", "PICKING")
  label      String
  sortOrder  Int
  isTerminal Boolean  @default(false) // 출고완료 단계 여부
  color      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?

  shipments Shipment[]

  @@index([sortOrder])
  @@schema("tenant_altibio")
}

model Shipment {
  id             String    @id @default(cuid())
  orderId        String
  currentStageId String
  enteredStageAt DateTime  @default(now())
  holdReason     String? // 보류 사유 (4/21 데모 피드백: QC 보류 버튼)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?

  // CASCADE: 주문 삭제 시 출고도 삭제
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  currentStage KanbanColumn       @relation(fields: [currentStageId], references: [id], onDelete: Restrict)
  stageHistory ShipmentStageLog[]
  assignees    ShipmentAssignee[]

  @@index([orderId])
  @@index([currentStageId])
  @@schema("tenant_altibio")
}

// 단계별 담당자 (R17) — 한 출고의 단계마다 다수 담당자 배정 가능
model ShipmentAssignee {
  id         String   @id @default(cuid())
  shipmentId String
  stageId    String // KanbanColumn.id
  userId     String // public.User.id (cross-schema 참조, 앱 레벨에서 검증)
  assignedAt DateTime @default(now())

  // CASCADE: 출고 삭제 시 담당자도 삭제
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, stageId, userId])
  @@index([userId])
  @@schema("tenant_altibio")
}

model ShipmentStageLog {
  id          BigInt   @id @default(autoincrement())
  shipmentId  String
  fromStageId String?
  toStageId   String
  movedBy     String? // userId
  movedAt     DateTime @default(now())
  note        String?

  // CASCADE: 출고 삭제 시 이력 삭제
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, movedAt])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R14: 재고 로그 및 조정 (반품 포함)
// ----------------------------------------------------------------------------

enum InventoryLogType {
  RESERVE // 주문 확정 → availableStock 차감
  RELEASE // 주문 취소 → availableStock 복구
  SHIP // 출고 → physicalStock 차감
  RECEIVE // 입고 → physicalStock 증가
  ADJUST_IN // 조정(+)
  ADJUST_OUT // 조정(-)
  RETURN // 반품 (조정의 특수 케이스)

  @@schema("tenant_altibio")
}

model InventoryLog {
  id             BigInt           @id @default(autoincrement())
  productSizeId  String
  type           InventoryLogType
  qtyDelta       Int // +/- 변화량
  physicalAfter  Int // 변동 후 실재고
  availableAfter Int // 변동 후 가용재고
  relatedOrderId String?
  note           String?
  createdAt      DateTime         @default(now())
  createdBy      String?

  // CASCADE: 제품사이즈 삭제 시 로그 삭제 (또는 보존하려면 SET NULL 로 변경)
  productSize ProductSize @relation(fields: [productSizeId], references: [id], onDelete: Cascade)

  @@index([productSizeId, createdAt])
  @@schema("tenant_altibio")
}

// 반품 / 입고조정 / 폐기 등 수기 조정 (CLAUDE.md: 반품 = reason='반품')
model InventoryAdjustment {
  id            String   @id @default(cuid())
  productSizeId String
  qty           Int // 양수 = 입고/반품, 음수 = 폐기
  reason        String // "반품" | "입고" | "폐기" | "실사조정" 등
  note          String?
  approvedBy    String?
  createdAt     DateTime @default(now())
  createdBy     String?

  productSize ProductSize @relation(fields: [productSizeId], references: [id], onDelete: Cascade)

  @@index([productSizeId, createdAt])
  @@index([reason])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R07, R09, R10, R18: 거래명세서 / 원장 / 마감
// ----------------------------------------------------------------------------

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  CANCELLED

  @@schema("tenant_altibio")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  orderId       String? // 발주 건 기반이면 연결
  issueDate     DateTime
  dueDate       DateTime?
  supplyAmount  Decimal       @db.Decimal(14, 2) // 공급가액
  vatAmount     Decimal       @db.Decimal(14, 2) // R18 부가세 10%
  totalAmount   Decimal       @db.Decimal(14, 2)
  status        InvoiceStatus @default(DRAFT)
  pdfUrl        String?
  sentAt        DateTime?
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String?

  // CASCADE: 거래처 삭제 시 RESTRICT, 주문 삭제 시 SET NULL
  client Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  order  Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items  InvoiceItem[]

  @@index([clientId, issueDate])
  @@index([status])
  @@schema("tenant_altibio")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(14, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@schema("tenant_altibio")
}

// R10: 월 마감 원장
model ClosingLedger {
  id           String    @id @default(cuid())
  clientId     String
  closingMonth String // "2026-04"
  carryOver    Decimal   @default(0) @db.Decimal(14, 2) // 전월 이월
  monthlySales Decimal   @default(0) @db.Decimal(14, 2) // 당월 매출
  received     Decimal   @default(0) @db.Decimal(14, 2) // 당월 수금
  balance      Decimal   @default(0) @db.Decimal(14, 2) // 잔액
  note         String?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@unique([clientId, closingMonth])
  @@index([closingMonth])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R12: 수금 관리 (일부입금, 은행 수기 입력, 미수금)
// ----------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  PARTIAL // 일부입금
  PAID
  OVERDUE

  @@schema("tenant_altibio")
}

model Payment {
  id        String        @id @default(cuid())
  clientId  String
  amount    Decimal       @db.Decimal(14, 2)
  paidAt    DateTime
  method    String // "계좌이체" | "카드" | "현금" 등
  status    PaymentStatus @default(PENDING)
  bankTxnId String? // BankTransaction 연결
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  createdBy String?

  client  Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  bankTxn BankTransaction? @relation(fields: [bankTxnId], references: [id], onDelete: SetNull)

  @@index([clientId, paidAt])
  @@schema("tenant_altibio")
}

// 은행 입금 수기 입력 (R12 프로토타입 요구사항)
model BankTransaction {
  id        String   @id @default(cuid())
  bankName  String
  payer     String // 입금자
  amount    Decimal  @db.Decimal(14, 2)
  txnDate   DateTime
  reference String?
  matched   Boolean  @default(false) // Payment 와 매칭 여부
  createdAt DateTime @default(now())
  createdBy String?

  payments Payment[]

  @@index([txnDate])
  @@index([matched])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R15, R21, R23: 영업 (실적, 담당자 배정, 학회·방문)
// ----------------------------------------------------------------------------

// 담당자-거래처 배정 (R11, R23)
model SalesAssignment {
  id         String   @id @default(cuid())
  clientId   String
  salesRepId String // public.User.id
  assignedAt DateTime @default(now())
  active     Boolean  @default(true)
  createdBy  String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, salesRepId])
  @@index([salesRepId])
  @@schema("tenant_altibio")
}

// R23: 학회
model Conference {
  id        String    @id @default(cuid())
  name      String
  location  String?
  startDate DateTime
  endDate   DateTime?
  note      String?
  createdAt DateTime  @default(now())
  createdBy String?

  visitors ConferenceVisitor[]

  @@index([startDate])
  @@schema("tenant_altibio")
}

// R23: 방문자 방명록
model ConferenceVisitor {
  id            String   @id @default(cuid())
  conferenceId  String
  name          String
  phone         String?
  affiliation   String? // 소속
  assignedRepId String? // 담당자 배정
  contactStatus String? // "신규" | "접촉중" | "계약" 등
  note          String?
  createdAt     DateTime @default(now())
  createdBy     String?

  conference Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@index([conferenceId])
  @@index([assignedRepId])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R20: 판매 계약서
// ----------------------------------------------------------------------------

model SalesContract {
  id        String    @id @default(cuid())
  clientId  String
  title     String
  startDate DateTime
  endDate   DateTime?
  pdfUrl    String?
  signed    Boolean   @default(false)
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?

  // 거래처 삭제 시 계약도 함께 제거 (감사 이력은 AuditLog 로 이미 누적됨)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([endDate])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R22: 데이터 사용량 수기 입력
// ----------------------------------------------------------------------------

model DataUsage {
  id        String   @id @default(cuid())
  month     String // "2026-04"
  category  String // "서버" | "스토리지" | "이메일" 등
  amount    Decimal  @db.Decimal(14, 2)
  unit      String // "GB" | "건" 등
  note      String?
  createdAt DateTime @default(now())
  createdBy String?

  @@unique([month, category])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// R24: 임원진 대시보드 — 위젯 커스터마이징
// ----------------------------------------------------------------------------

model DashboardWidget {
  id                String   @id @default(cuid())
  userId            String // public.User.id
  preset            String // "sales_total", "order_status", "inventory_alert" 등
  position          Int
  width             Int      @default(6) // grid cols 1-12
  height            Int      @default(4)
  overrideDateRange String? // null = 전역값 사용
  config            Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, position])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// 알림 / 이메일 큐 (R14, 재고알람 + 거래명세서 발송)
// ----------------------------------------------------------------------------

enum NotificationChannel {
  IN_APP
  EMAIL

  @@schema("tenant_altibio")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String // public.User.id
  channel   NotificationChannel
  title     String
  body      String
  readAt    DateTime?
  link      String?
  createdAt DateTime            @default(now())

  @@index([userId, readAt])
  @@schema("tenant_altibio")
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  FAILED

  @@schema("tenant_altibio")
}

model EmailQueue {
  id          String      @id @default(cuid())
  toAddress   String
  ccAddress   String?
  subject     String
  body        String
  template    String? // 템플릿 키
  attachments Json? // [{filename, url}]
  status      EmailStatus @default(QUEUED)
  sentAt      DateTime?
  errorMsg    String?
  retryCount  Int         @default(0)
  createdAt   DateTime    @default(now())

  @@index([status])
  @@index([createdAt])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// 테넌트 설정 (R13: 업무시간, 택배 마감시간 등)
// ----------------------------------------------------------------------------

model TenantSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@schema("tenant_altibio")
}

// ============================================================================
// ▼ Phase 5 신규 모듈 (2026-05-22)
// ============================================================================

// ----------------------------------------------------------------------------
// 공지사항 (4팀 → 거래처 발송)
//   - createdByTeam: '경영지원팀' | '영업팀' | '품질관리팀' | '임원진'
//   - target: ALL / DEALER / HOSPITAL / SPECIFIC
//   - targetClients[]: SPECIFIC 일 때 대상 거래처 목록 (M:N via NoticeRecipient)
//   - readBy[]: 거래처별 읽음 상태 (NoticeReadLog)
// ----------------------------------------------------------------------------

enum NoticeTarget {
  ALL // 전체 거래처
  DEALER // 대리점만
  HOSPITAL // 병원만
  SPECIFIC // 특정 거래처

  @@schema("tenant_altibio")
}

enum NoticePriority {
  NORMAL
  HIGH

  @@schema("tenant_altibio")
}

model Notice {
  id            String         @id @default(cuid())
  title         String
  body          String         @db.Text
  target        NoticeTarget
  priority      NoticePriority @default(NORMAL)
  pinned        Boolean        @default(false)
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String // User.id
  createdByTeam String // '경영지원팀' / '영업팀' / '품질관리팀' / '임원진'

  // SPECIFIC 발송 대상 거래처 (M:N)
  recipients NoticeRecipient[]
  // 읽음 로그
  readLogs   NoticeReadLog[]

  @@index([createdAt])
  @@index([priority, pinned])
  @@schema("tenant_altibio")
}

model NoticeRecipient {
  id       String @id @default(cuid())
  noticeId String
  clientId String

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([noticeId, clientId])
  @@index([clientId])
  @@schema("tenant_altibio")
}

model NoticeReadLog {
  id            String   @id @default(cuid())
  noticeId      String
  clientId      String
  readAt        DateTime @default(now())
  // "다시 보지 않기" 체크 — 거래처 포털 팝업 안 뜸
  dontShowAgain Boolean  @default(false)

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([noticeId, clientId])
  @@index([clientId])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// 베트남 발주 트래킹 (생산 발주 → 항공/선박 분할 입고)
// ----------------------------------------------------------------------------

enum ProcurementCategory {
  FABRIC // 원단
  MATERIAL // 부자재
  PRODUCT // 제품

  @@schema("tenant_altibio")
}

enum ProcurementStatus {
  PENDING // 대기
  IN_PRODUCTION // 생산중
  SHIPPING // 출고중
  PARTIAL // 부분입고
  COMPLETED // 입고완료

  @@schema("tenant_altibio")
}

enum ShipmentTransport {
  AIR // 항공 ✈️
  SEA // 선박 🚢

  @@schema("tenant_altibio")
}

model ProcurementProject {
  id             String              @id @default(cuid())
  code           String              @unique // PRJ-YYMMNN
  title          String
  category       ProcurementCategory
  status         ProcurementStatus   @default(PENDING)
  orderDate      DateTime
  plannedArrival DateTime?
  totalQty       Int                 @default(0)
  receivedQty    Int                 @default(0)
  note           String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String

  shipments ProcurementShipment[]

  @@index([category, status])
  @@index([orderDate])
  @@schema("tenant_altibio")
}

model ProcurementShipment {
  id             String            @id @default(cuid())
  projectId      String
  transport      ShipmentTransport
  qty            Int
  departureDate  DateTime?
  arrivalDate    DateTime? // 입고일
  expectedDate   DateTime? // 예상 입항일
  trackingNumber String?
  note           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project ProcurementProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// UDI 공급내역 보고 (월별 병원 납품 자동 집계)
// ----------------------------------------------------------------------------

enum UdiReportStatus {
  DRAFT // 작성중
  SUBMITTED // 식약처 전송완료
  ACCEPTED // 접수번호 발급

  @@schema("tenant_altibio")
}

model UdiReport {
  id          String          @id @default(cuid())
  reportMonth String // YYYY-MM
  status      UdiReportStatus @default(DRAFT)
  receiptNo   String? // 식약처 접수번호 (ACCEPTED 시 발급)
  submittedAt DateTime?
  totalItems  Int             @default(0)
  totalAmount Decimal         @default(0) @db.Decimal(15, 2)
  note        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String

  items UdiReportItem[]

  @@unique([reportMonth])
  @@schema("tenant_altibio")
}

model UdiReportItem {
  id          String   @id @default(cuid())
  reportId    String
  clientId    String // 거래처(병원)
  bizNumber   String // 사업자등록번호
  productId   String?
  udiCode     String // UDI-DI 14자리
  productName String
  spec        String?
  qty         Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalAmount Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())

  report UdiReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  client Client    @relation(fields: [clientId], references: [id])

  @@index([reportId])
  @@index([clientId])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// 매뉴얼·절차서·양식 카탈로그 (ISO 13485)
// ----------------------------------------------------------------------------

enum QualityDocKind {
  MANUAL // 매뉴얼 (M)
  PROCEDURE // 절차서 (P)
  FORM // 양식 (F)

  @@schema("tenant_altibio")
}

model QualityDocument {
  id          String         @id @default(cuid())
  code        String         @unique // 예: "F401", "P101", "M001"
  title       String
  kind        QualityDocKind
  category    String? // "교육훈련" / "공정관리" / "고객불만" 등
  revision    String?
  effectiveAt DateTime?
  filePath    String? // Blob Storage 경로
  description String?        @db.Text
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdBy   String

  @@index([kind, active])
  @@index([category])
  @@schema("tenant_altibio")
}

// ----------------------------------------------------------------------------
// 매입매출 거래원장 (데이터 탐색기 — 엑셀/CSV 업로드 데이터 저장소)
//   - 2023.01 ~ 2026.05 알티바이오 거래 데이터 41,537 행 시드
//   - 영업/경영지원/품질 포털 모두 조회·다운로드 가능
//   - 필터: 날짜/거래처/품목/구분(매출/매입)
// ----------------------------------------------------------------------------

enum TxnKind {
  SALE // 매출
  PURCHASE // 매입

  @@schema("tenant_altibio")
}

model TransactionLedger {
  id           String   @id @default(cuid())
  txnDate      DateTime // 거래일자
  kind         TxnKind // 매출/매입
  taxType      String? // 과세/면세/영세
  clientCode   String? // 거래처 코드 (엑셀 D열)
  clientName   String? // 거래처명 (엑셀 E열)
  productCode  String? // 품목코드
  productName  String // 품목명
  spec         String? // 규격 (S/M/L/XL)
  unit         String? // 단위 (EA(편측))
  qty          Decimal  @db.Decimal(14, 4) // 수량
  unitPrice    Decimal  @db.Decimal(14, 2) // 단가
  supplyAmount Decimal  @db.Decimal(15, 2) // 공급가
  vat          Decimal  @db.Decimal(15, 2) // 부가세
  totalAmount  Decimal  @db.Decimal(15, 2) // 합계금액
  itemMemo     String? // 품목비고
  voucherNo    String? // 전표번호 (예: S2600426)
  hasInvoice   Boolean  @default(false) // 거래명세표 발급 여부 (O/X)
  evidence     String? // 증빙
  category     String? // 거래범주 (예: "병원(박진우 과장님)")
  memo         String? // 비고 (예: "*직납")
  importSource String? // 'excel:filename' / 'csv:filename' / 'manual'
  importedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  createdBy    String?

  @@index([txnDate])
  @@index([clientCode])
  @@index([productCode])
  @@index([kind, txnDate])
  @@index([voucherNo])
  @@schema("tenant_altibio")
}
